          const __revalUCtx = _createUnifiedCtx({
            headersContext: __revalHeadCtx,
            executionContext: _getRequestExecutionContext(),
          });
          await _runWithUnifiedCtx(__revalUCtx, async () => {
            _ensureFetchPatch();
            await renderFn();
